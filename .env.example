# StockIt — 퀵스타트 환경변수 템플릿
# 사용: cp .env.example .env  후 OPENAI_API_KEY 만 채우면 바로 동작

# ─── 필수 ─────────────────────────────────────────────────────────
# AI 거래처 추천(ADR-021) 에 사용. 키가 없으면 추천 엔드포인트가 실패한다.
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-REPLACE_ME

# JWT 서명용 비밀키. HS512 라 32바이트 이상 권장 — 처음 띄울 때는 그대로 둬도 OK
JWT_SECRET=stockit-quickstart-jwt-secret-please-replace-in-real-deployment-64bytes

# ─── 선택 ─────────────────────────────────────────────────────────
# 탄소 가격 공공데이터 API 키. 없어도 BE 가 fallback-price(9200원) 로 동작.
PUBLIC_DATA_API_KEY=

# 이미지 핀 (특정 빌드 번호로 고정하고 싶을 때)
# BE_IMAGE=sunyeoplee/stockit-backend:128
# FE_IMAGE=saralove20/stockit-front:v82

# 시드 가져올 BE 레포 브랜치 (보통 그대로)
# SEED_BRANCH=main

# DB
# DB_NAME=stockit
# DB_USER=stockit
# DB_PASS=stockit1234
# DB_ROOT_PASS=rootstockit1234

# 포트
# FE_PORT=8888       # 메인 접속 포트 (FE + /api 프록시)
# BE_PORT=8080       # BE 직접 노출 (Swagger 등)
# DB_PORT=3306
# ES_PORT=9200
# KIBANA_PORT=5601

# ES
# ES_VERSION=8.15.3
